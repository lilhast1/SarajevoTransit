{
  "info": {
    "name": "User Service API",
    "_postman_id": "9f24e5f9-bb8f-4c0f-9a76-7b4cdfe8f9a2",
    "description": "Collection for User Service API assignment documentation and request-response testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Profiles",
      "item": [
        {
          "name": "US-S-01 Create user success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Lejla Music\",\n  \"email\": \"LEJLA.MUSIC@SARAJEVOTRANSIT.BA\",\n  \"password\": \"StrongPass123\",\n  \"languageCode\": \"BS\",\n  \"themeMode\": \"SYSTEM\",\n  \"notificationChannel\": \"PUSH\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has id', function () { pm.expect(pm.response.json().id).to.be.a('number'); });",
                  "pm.test('Email normalized', function () { pm.expect(pm.response.json().email).to.eql('lejla.music@sarajevotransit.ba'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "US-F-01 Create user failure",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"\",\n  \"email\": \"not-an-email\",\n  \"password\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Validation error present', function () { pm.expect(pm.response.json().message).to.eql('Validation failed'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Get user summary",
          "request": {
