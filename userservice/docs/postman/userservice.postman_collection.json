              "raw": "{\n  \"points\": 80,\n  \"description\": \"Ride discount\",\n  \"referenceType\": \"discount\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/loyalty/redeem",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "loyalty",
                "redeem"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Business error message present', function () { pm.expect(pm.response.json().message).to.eql('User does not have enough loyalty points for redemption.'); });"
                ]
