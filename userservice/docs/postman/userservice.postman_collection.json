    {
      "name": "Loyalty",
      "item": [
        {
          "name": "LS-S-01 Earn points success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"points\": 50,\n  \"description\": \"Ticket purchase bonus\",\n  \"referenceType\": \"ticket_purchase\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/loyalty/earn",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "{{userId}}",
                "loyalty",
                "earn"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(201); });",
                  "pm.test('Balance field present', function () { pm.expect(pm.response.json().currentBalance).to.be.a('number'); });"
                ]
              }
            }
          ]
        },
