  "item": [
    {
      "name": "Problem Reports",
      "item": [
        {
          "name": "PR-S-01 Create report success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reporterUserId\": 5101,\n  \"lineId\": 6,\n  \"stationId\": 18,\n  \"category\": \"DELAY\",\n  \"description\": \"Delay around 8 minutes at evening peak.\",\n  \"photoUrls\": [\n    \"https://example.com/evidence/report-ok.png\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reports"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Response has id', function () { pm.expect(pm.response.json().id).to.be.a('number'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "PR-F-01 Create report failure",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reporterUserId\": -1,\n  \"lineId\": 6,\n  \"description\": \"\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reports"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () { pm.response.to.have.status(400); });",
                  "pm.test('Validation message present', function () { pm.expect(pm.response.json().message).to.eql('Validation failed'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get reports",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reports"
              ]
            }
          }
        },
        {
          "name": "Get reports by line",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/line/{{lineId}}",
              "host": [
